---
// Dismissible banner encouraging contributions
// Renders above the fixed Starlight header and shifts layout down via --sl-banner-height.
import { getTranslations } from "../lib/translations";

const locale = Astro.locals.starlightRoute?.lang || "en";
const t = getTranslations(locale as "en" | "ru");
---

<div id="contribute-banner" class="contribute-banner">
  <div class="banner-content">
    <span class="banner-icon">🌟</span>
    <span class="banner-text">
      <strong>{t.contributeBanner.heading}</strong> {t.contributeBanner.body}
      <a href="https://github.com/Kilo-Org/agentic-path" target="_blank" rel="noopener">{t.contributeBanner.action}</a>
    </span>
  </div>
  <button id="dismiss-banner" class="dismiss-btn" aria-label={t.contributeBanner.dismiss}>×</button>
</div>

<style>
  .contribute-banner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem 1rem;
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
    border-bottom: 1px solid #30363d;
    font-size: 0.85rem;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: calc(var(--sl-z-index-navbar) + 1);
  }

  :global([data-theme='light']) .contribute-banner {
    background: linear-gradient(135deg, #f0f4ff 0%, #e8f0fe 100%);
    border-bottom: 1px solid #d0d7de;
  }

  .banner-content {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .banner-icon {
    font-size: 1rem;
  }

  .banner-text {
    color: #c9d1d9;
  }

  :global([data-theme='light']) .banner-text {
    color: #24292f;
  }

  .banner-text a {
    color: #58a6ff;
    text-decoration: none;
    font-weight: 500;
  }

  .banner-text a:hover {
    text-decoration: underline;
  }

  :global([data-theme='light']) .banner-text a {
    color: #0969da;
  }

  .dismiss-btn {
    background: none;
    border: none;
    color: #8b949e;
    font-size: 1.25rem;
    cursor: pointer;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    border-radius: 4px;
    transition: background-color 0.2s;
    flex-shrink: 0;
  }

  .dismiss-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    color: #c9d1d9;
  }

  :global([data-theme='light']) .dismiss-btn:hover {
    background: rgba(0, 0, 0, 0.05);
    color: #24292f;
  }

  .contribute-banner.hidden {
    display: none;
  }
</style>

<script>
  function initBanner() {
    const banner = document.getElementById('contribute-banner');
    const dismissBtn = document.getElementById('dismiss-banner');
    const storageKey = 'contribute-banner-dismissed';

    function updateBannerOffset() {
      if (banner && !banner.classList.contains('hidden')) {
        const height = banner.offsetHeight;
        document.documentElement.style.setProperty('--sl-contribute-banner-height', `${height}px`);
      } else {
        document.documentElement.style.setProperty('--sl-contribute-banner-height', '0px');
      }
    }

    // Check if banner was previously dismissed
    if (localStorage.getItem(storageKey) === 'true') {
      banner?.classList.add('hidden');
    }

    updateBannerOffset();

    dismissBtn?.addEventListener('click', () => {
      banner?.classList.add('hidden');
      localStorage.setItem(storageKey, 'true');
      updateBannerOffset();
    });

    // Recalculate on resize in case text wraps differently
    window.addEventListener('resize', updateBannerOffset);
  }

  // Run on initial load
  initBanner();

  // Re-run after Astro view transitions (Starlight uses them)
  document.addEventListener('astro:after-swap', initBanner);
</script>
